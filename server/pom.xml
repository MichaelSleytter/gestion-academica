<?xml version="1.0" encoding="UTF-8" ?>
<project
    xmlns="http://maven.apache.org/POM/4.0.0"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
         https://maven.apache.org/xsd/maven-4.0.0.xsd"
>

    <modelVersion>4.0.0</modelVersion>

    <!-- ============================================
         PARENT — Spring Boot 3.5.13
         ============================================ -->
    <parent>
        <groupId>org.springframework.boot</groupId>
        <artifactId>spring-boot-starter-parent</artifactId>
        <version>3.5.13</version>
        <relativePath />
    </parent>

    <!-- ============================================
         IDENTIFICACIÓN DEL PROYECTO
         ============================================ -->
    <groupId>com.example</groupId>
    <artifactId>gestion-academica</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>
    <name>gestion-academica</name>
    <description
    >Sistema de Gestión Académica Universitaria - TechNova Solutions</description>

    <!-- ============================================
         PROPIEDADES GLOBALES
         ============================================ -->
    <properties>
        <java.version>21</java.version>

        <springdoc.version>2.8.6</springdoc.version>
    </properties>

    <!-- ============================================
         DEPENDENCIAS
         ============================================ -->
    <dependencies>

        <!-- ── WEB ─────────────────────────────────── -->

        <!-- Spring Web: REST API, controladores HTTP -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
        </dependency>

        <!-- ── PERSISTENCIA ────────────────────────── -->

        <!-- Spring Data JPA: repositorios, entidades, Hibernate -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-data-jpa</artifactId>
        </dependency>

        <!-- Conector para PostgreSQL -->
        <dependency>
            <groupId>org.postgresql</groupId>
            <artifactId>postgresql</artifactId>
            <scope>runtime</scope>
        </dependency>

        <!-- ── VALIDACIÓN ──────────────────────────── -->

        <!-- Bean Validation / Jakarta Validation (@NotBlank, @Email, etc.) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-validation</artifactId>
        </dependency>

        <!-- ── UTILIDADES ──────────────────────────── -->

        <!-- Lombok: @Getter, @Setter, @Builder, @RequiredArgsConstructor -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- ── DOCUMENTACIÓN ───────────────────────── -->

        <!-- Springdoc OpenAPI: Swagger UI en /swagger-ui.html -->
        <!-- ✅ 2.8.6 es compatible con Spring Boot 3.5.x + Spring 6.2.x -->
        <dependency>
            <groupId>org.springdoc</groupId>
            <artifactId>springdoc-openapi-starter-webmvc-ui</artifactId>
            <version>${springdoc.version}</version>
        </dependency>

        <!-- ── TESTING ─────────────────────────────── -->

        <!-- Spring Boot Test: JUnit 5 + Mockito + AssertJ incluidos -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>
        <!-- Spring Boot DevTools: reinicio automático en desarrollo -->
        <dependency>
		<groupId>org.springframework.boot</groupId>
		<artifactId>spring-boot-devtools</artifactId>
		<optional>true</optional>
	</dependency>

        <!-- Spring Security crypto module: BCryptPasswordEncoder standalone -->
        <dependency>
            <groupId>org.springframework.security</groupId>
            <artifactId>spring-security-crypto</artifactId>
        </dependency>

        <!-- ── SEGURIDAD JWT ─────────────────────────── -->

        <!-- Spring Security starter (automatiza configuración de Security) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-security</artifactId>
        </dependency>

        <!-- JJWT: biblioteca para crear y validar JWT tokens -->
        <!-- jjwt-api: clases base para crear tokens -->
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-api</artifactId>
            <version>0.12.5</version>
        </dependency>
        <!-- jjwt-impl: implementación de la lógica -->
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-impl</artifactId>
            <version>0.12.5</version>
            <scope>runtime</scope>
        </dependency>
        <!-- jjwt-jackson: soporte para JSON (necesario para serializar claims) -->
        <dependency>
            <groupId>io.jsonwebtoken</groupId>
            <artifactId>jjwt-jackson</artifactId>
            <version>0.12.5</version>
            <scope>runtime</scope>
        </dependency>
        <!-- Java Mail (para enviar correos electrónicos) -->
        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-mail</artifactId>
        </dependency>
    </dependencies>

    <!-- ============================================
         BUILD
         ============================================ -->
    <build>
        <plugins>

            <!-- Plugin principal de Spring Boot -->
            <plugin>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-maven-plugin</artifactId>
                <configuration>
                    <!-- Excluir Lombok del JAR final (solo se usa en compilación) -->
                    <excludes>
                        <exclude>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </exclude>
                    </excludes>
                </configuration>
            </plugin>

            <!-- Compilador Java — fuerza Java 21 explícitamente -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <configuration>
                    <source>${java.version}</source>
                    <target>${java.version}</target>
                    <annotationProcessorPaths>
                        <!-- Lombok debe estar como annotation processor -->
                        <path>
                            <groupId>org.projectlombok</groupId>
                            <artifactId>lombok</artifactId>
                        </path>
                    </annotationProcessorPaths>
                </configuration>
            </plugin>

        </plugins>
    </build>

</project>
