# ─── Base de datos PostgreSQL ────────────────────────────────────────
DB_URL=
DB_USERNAME=
DB_PASSWORD=

# ─── Servidor ────────────────────────────────────────────────────────
PORT_BACKEND=8080
CORS_ALLOWED_ORIGIN=

# ─── JWT (generá clave con: openssl rand -base64 32) ─────────────────
JWT_SECRET=
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION_DAYS=7

# ─── SMTP (Gmail con contraseña de aplicación) ───────────────────────
MAIL_USERNAME=tu-cuenta@gmail.com
MAIL_PASSWORD=
MAIL_FROM=tu-cuenta@gmail.com

# ─── Frontend (para enlaces de reset password) ───────────────────────
FRONTEND_BASE_URL=http://localhost:4200

# ─── Reglas de dominio ───────────────────────────────────────────────
STUDENT_EMAIL_DOMAIN=institution.edu.pe

# ─── Reset password ──────────────────────────────────────────────────
PASSWORD_RESET_EXPIRATION_MINUTES=30

# ─── InsForge Storage ────────────────────────────────────────────────
INSFORGE_URL=https://3auan78u.us-east.insforge.app
INSFORGE_API_KEY=

# ─── Uploads ─────────────────────────────────────────────────────────
MAX_UPLOAD_FILE_SIZE=25MB
MAX_UPLOAD_REQUEST_SIZE=30MB
