{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/universidad-taiga/browser",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://gestion-academica-production.up.railway.app/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
